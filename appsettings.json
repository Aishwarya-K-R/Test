{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },

  "ConnectionStrings": {
    "DefaultConnection": "",
    "RedisConnection": ""
  },

  "BillingService": {
    "Address": "billing-service",
    "Port": "9001"
  },

  "Kafka": {
    "BootstrapServers": "kafka:9092",
    "PatientCreatedTopic": "patient-created",
    "PatientUpdatedTopic": "patient-updated",
    "PatientDeletedTopic": "patient-deleted",
    "BillingCreatedTopic": "billing-created"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "patient-route": {
        "ClusterId": "patient-cluster",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/ai/{**catch-all}"
        }
      }    
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": {
            "Address": "http://auth-service:4005/"
          }
        }
      },
      "patient-cluster": {
        "Destinations": {
          "patient-service": {
            "Address": "http://patient-service:5244/"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "ai-service": {
            "Address": "http://ai-service:5000/"
          }
        }
      }     
    }
  },

  "Jwt": {
    "Key": "",
    "Issuer": "localhost",
    "Audience": "localhost"
  },

  "Services": {
    "Auth": "http://auth-service:4005/health",
    "Patient": "http://patient-service:5244/health"
  },

  "RedisKeys": {
    "UpdatedPatientsKey": "updated-patients"
  },

  "AllowedHosts": "*"
}

